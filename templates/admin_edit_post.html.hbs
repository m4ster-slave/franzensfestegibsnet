{{#*inline "header"}}
<link rel="stylesheet" href="/css/admin_post_edit.css">
{{/inline}}

{{#> layout title="Edit Post"}}
{{#*inline "page_content"}}
<div class="admin-edit-container">
  <div class="admin-header">
    <h1>Edit Post</h1>
    <div class="header-actions">
      <a href="/admin/moderation" class="btn-secondary">Back to Moderation</a>
    </div>
  </div>

  {{#if error}}
    <div class="error-message"><p>{{error}}</p></div>
  {{/if}}

  {{#with rendered_post.post}}
  <div class="edit-section">
    <h2>Post Details</h2>
    <form action="/admin/posts/{{id}}/edit" method="POST" class="edit-form">
      <div class="form-group">
        <label for="title">Title</label>
        <input type="text" id="title" name="title" value="{{title}}" required>
      </div>

      <div class="form-group">
        <label for="content">Markdown Content</label>
        <textarea id="content" name="content" required rows="10">{{content}}</textarea>
      </div>

      <div class="post-meta">Status: {{status}} · Locked: {{locked}}</div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
  {{/with}}

  <div class="edit-section">
    <h2>Rendered Preview</h2>
    <div class="post-content">{{{rendered_post.content_html}}}</div>
  </div>

  <div class="comments-section">
    <h2>Comments</h2>
    {{#each comments}}
    <div class="comment-card" id="comment-{{comment.id}}">
      <div class="comment-meta">
        Posted on {{format_date comment.created_at}} · {{comment.status}}
      </div>
      <div class="comment-content">
        <form action="/admin/comments/{{comment.id}}/edit" method="POST" class="comment-edit-form">
          <div class="form-group">
            <textarea name="content" required>{{comment.content}}</textarea>
          </div>
          <div class="comment-actions">
            <button type="submit" class="btn-save">Save Changes</button>
          </div>
        </form>
        <form action="/admin/comments/{{comment.id}}/moderate" method="POST" class="moderation-form">
          <select name="status">
            <option value="{{comment.status}}">{{comment.status}}</option>
            <option value="visible">visible</option>
            <option value="hidden">hidden</option>
            <option value="removed">removed</option>
          </select>
          <input type="text" name="moderator_note" value="{{comment.moderator_note}}" placeholder="Moderator note">
          <button type="submit" class="btn-save">Moderate</button>
        </form>
        <div class="post-content">{{{content_html}}}</div>
      </div>
    </div>
    {{else}}
    <p class="no-comments">No comments on this post.</p>
    {{/each}}
  </div>
</div>
{{/inline}}
{{/layout}}
