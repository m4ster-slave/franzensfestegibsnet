{{#*inline "header"}}
<link rel="stylesheet" href="/css/forum_create_style.css">
<script type="module" src="/js/createpost.js"></script>
<script type="module" src="/js/uploads.js"></script>
{{/inline}}

{{#> layout title="New Report"}}
{{#*inline "page_content"}}
<section class="forum-post-container dossier-page">
  <header class="page-intro page-intro--compact">
    <p class="eyebrow">New evidence intake</p>
    <h1>Open a Field Report</h1>
  </header>

  {{#if error}}
  <div class="error-message"><p>{{error}}</p></div>
  {{/if}}

  <form action="/forum/create" method="POST" id="postForm" class="evidence-form">
    <div class="form-group">
      <label for="title">Report title</label>
      <input type="text" id="title" name="title" required placeholder="What did you notice?" />
    </div>

    <div class="form-group">
      <label for="content">Markdown content</label>
      <textarea id="content" name="content" required placeholder="File your observation. Markdown accepted."></textarea>
    </div>

    <input type="hidden" id="fingerprint" name="fingerprint" value="" />
    <button type="submit" class="btn btn-primary" id="submitButton">Submit report</button>
  </form>

  <form class="upload-form" data-upload-target="content">
    <div class="form-group">
      <label for="post_image">Insert local image</label>
      <input type="file" id="post_image" name="file" accept="image/png,image/jpeg,image/webp,image/gif">
    </div>
    <button type="submit" class="btn btn-secondary">Upload image</button>
    <span class="upload-result"></span>
  </form>

  <div class="form-footer">
    <a href="/forum" class="back-link">Back to forum</a>
  </div>
</section>
{{/inline}}
{{/layout}}
