{{#*inline "header"}}
<link rel="stylesheet" href="/css/admin_style.css">
{{/inline}}

{{#> layout title="Users"}}
{{#*inline "page_content"}}
<div class="admin-panel-container">
  <div class="admin-header">
    <div>
      <p class="eyebrow">Access registry</p>
      <h1>Users</h1>
    </div>
    <a href="/admin" class="btn-edit">Dashboard</a>
  </div>

  {{#if error}}
    <div class="error-message"><p>{{error}}</p></div>
  {{/if}}

  <div class="user-admin-list">
    {{#each users}}
    <article class="admin-user-card evidence-card">
      <div class="admin-user-card__identity">
        {{#if this.avatar_url}}
        <img class="admin-user-card__avatar" src="{{this.avatar_url}}" alt="" width="68" height="68" loading="lazy" decoding="async">
        {{else}}
        <div class="admin-user-card__avatar admin-user-card__avatar--empty">ID</div>
        {{/if}}
        <div>
          <h2>{{this.username}}</h2>
          <p>{{this.email}}</p>
          <div class="admin-user-card__meta">
            <span class="status-pill">{{this.role}}</span>
            <span class="status-pill">{{#if this.disabled}}disabled{{else}}active{{/if}}</span>
          </div>
        </div>
      </div>

      <div class="admin-user-card__controls">
        <form action="/admin/users/{{this.id}}/role" method="POST" class="inline-form">
          <label for="role-{{this.id}}">Role</label>
          <select id="role-{{this.id}}" name="role">
            <option value="{{this.role}}">{{this.role}}</option>
            <option value="user">user</option>
            <option value="moderator">moderator</option>
            <option value="admin">admin</option>
          </select>
          <button type="submit" class="btn-save">Save</button>
        </form>

        <form action="/admin/users/{{this.id}}/password" method="POST" class="inline-form">
          <label for="password-{{this.id}}">Password</label>
          <input type="password" id="password-{{this.id}}" name="password" minlength="8" required placeholder="New password">
          <button type="submit" class="btn-save">Reset</button>
        </form>

        {{#if this.disabled}}
        <form action="/admin/users/{{this.id}}/enable" method="POST" class="inline-form">
          <button type="submit" class="btn-save">Enable</button>
        </form>
        {{else}}
        <form action="/admin/users/{{this.id}}/disable" method="POST" class="inline-form">
          <button type="submit" class="btn-delete">Disable</button>
        </form>
        {{/if}}
      </div>
    </article>
    {{else}}
    <div class="empty-state">
      <p>No users found.</p>
    </div>
    {{/each}}
  </div>
</div>
{{/inline}}
{{/layout}}
