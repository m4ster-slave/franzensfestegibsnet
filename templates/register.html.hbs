{{#*inline "header"}}
<link rel="stylesheet" href="/css/admin_style.css">
{{/inline}}

{{#> layout title="Register"}}
{{#*inline "page_content"}}
<section class="admin-login-container auth-panel">
  <p class="eyebrow">Create field identity</p>
  <h1>Register</h1>

  {{#if error}}
    <div class="error-message">
      <p>{{error}}</p>
    </div>
  {{/if}}

  <form action="/register" method="POST" class="admin-login-form evidence-form">
    <div class="form-group">
      <label for="username">Username</label>
      <input type="text" id="username" name="username" required minlength="3">
    </div>

    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required>
    </div>

    <div class="form-group">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required minlength="8">
    </div>

    <button type="submit" class="btn-primary">Create Account</button>
  </form>
  <p class="auth-alt">Already cleared? <a href="/login">Login</a></p>
</section>
{{/inline}}
{{/layout}}
