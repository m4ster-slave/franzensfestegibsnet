{{#*inline "header"}}
<link rel="stylesheet" href="/css/admin_style.css">
{{/inline}}

{{#> layout title="Admin Panel"}}
{{#*inline "page_content"}}
<div class="admin-panel-container">
  <div class="admin-header">
    <div>
      <p class="eyebrow">Restricted desk</p>
      <h1>Admin Panel</h1>
    </div>
  </div>

  <div class="admin-nav">
    <a href="/admin/users" class="btn-edit">Users</a>
    <a href="/admin/articles" class="btn-edit">Articles</a>
    <a href="/admin/moderation" class="btn-edit">Moderation</a>
  </div>

  <div class="dashboard-grid">
    <div class="dashboard-card">
      <span class="dashboard-number">{{stats.users}}</span>
      <span>Users</span>
    </div>
    <div class="dashboard-card">
      <span class="dashboard-number">{{stats.posts_visible}}</span>
      <span>Visible Posts</span>
    </div>
    <div class="dashboard-card">
      <span class="dashboard-number">{{stats.posts_hidden}}</span>
      <span>Hidden Posts</span>
    </div>
    <div class="dashboard-card">
      <span class="dashboard-number">{{stats.posts_removed}}</span>
      <span>Removed Posts</span>
    </div>
    <div class="dashboard-card">
      <span class="dashboard-number">{{stats.comments_visible}}</span>
      <span>Visible Comments</span>
    </div>
    <div class="dashboard-card">
      <span class="dashboard-number">{{stats.comments_hidden}}</span>
      <span>Hidden Comments</span>
    </div>
    <div class="dashboard-card">
      <span class="dashboard-number">{{stats.articles_published}}</span>
      <span>Published Articles</span>
    </div>
    <div class="dashboard-card">
      <span class="dashboard-number">{{stats.articles_draft}}</span>
      <span>Draft Articles</span>
    </div>
  </div>
</div>
{{/inline}}
{{/layout}}
