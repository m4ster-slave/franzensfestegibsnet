{{#*inline "header"}}
<link rel="stylesheet" href="/css/index_style.css">
{{/inline}}

{{#> layout title="Home"}}
{{#*inline "page_content"}}
<section class="home-hero">
  <img src="/static/BIG_LIE.webp" alt="Franzensfeste evidence board" class="home-hero__image">
  <div class="home-hero__copy">
    <p class="eyebrow">Declassified fragment</p>
    <h1>The Franzensfeste Files</h1>
